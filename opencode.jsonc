{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio/qwen/qwen3.6-35b-a3b",
  "plugin": [],
  "small_model": "opencode/big-pickle",
  "agent": {
    "build": {
      "model": "lmstudio/qwen/qwen3.6-35b-a3b",
      "permission": {
        "task": "deny"
      }
    },
    "cheap": {
      "mode": "primary",
      "model": "opencode-go/kimi-k2.6",
      "prompt": "{file:./prompts/precise-prompt.md}",
      "permission": {
        "task": "deny"
      }
    },
    "planner": {
      "mode": "primary",
      "model": "opencode-go/kimi-k2.6",
      "prompt": "{file:./prompts/planner.md}",
      "description": "An agent that breaks down problems systematically and delegates to sub-agents",
      "permission": {
        "write": "allow",
        "edit": "allow"
      }
    },
    "ultraplanner": {
      "mode": "primary",
      "model": "openrouter/anthropic/claude-opus-4.7",
      "prompt": "{file:./prompts/planner.md}",
      "description": "An agent that breaks down complex problems with deep reasoning and delegates to sub-agents",
      "permission": {
        "write": "allow",
        "edit": "allow"
      }
    },
    "explore": {
      "model": "opencode-go/kimi-k2.6"
    },
    "general": {
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.6"
    },
    "plan": {
      "disable": true
    },
  },
  "formatter": {
    "markdown": {
      "command": [
        "pnpx",
        "remark-cli@12.0.1",
        "$FILE",
        "--rc-path",
        "./remarkrc",
        "--output"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen 3.6-35B-A3B",
          "limit": {
            "context": 128000,
            "output": 64000
          }
        },
        "ornith-1.0-35b": {
          "name": "Ornith 1.0-35B",
          "limit": {
            "context": 128000,
            "output": 64000
          }
        }
      }
    },
    "lmstudio-conradkoh.local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (conradkoh.local)",
      "options": {
        "baseURL": "http://conradkoh.local:1234/v1"
      },
      "models": {
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen 3.6-35B-A3B",
          "limit": {
            "context": 128000,
            "output": 64000
          }
        },
        "coherelabs.north-mini-code-1.0": {
          "name": "Cohere North Mini Code 1.0",
          "limit": {
            "context": 128000,
            "output": 64000
          }
        },
        "ornith-1.0-35b": {
          "name": "Ornith 1.0-35B",
          "limit": {
            "context": 128000,
            "output": 64000
          }
        }
      }
    },
    "opencode": {
      "whitelist": [
        "big-pickle",
        "minimax-m2.5-free",
        "glm-5-free",
        "glm-5",
        "kimi-k2.5-free"
      ]
    },
    "github-copilot": {
      "models": {
        "gpt-5.3-codex": {}
      },
      "blacklist": [
        "grok-code-fast-1",
        "gpt-5.1-codex",
        // "claude-haiku-4.5",
        "gemini-3-pro-preview",
        "oswe-vscode-prime",
        "gpt-5.1-codex-mini",
        "gpt-5.1",
        "gpt-5-codex",
        "gpt-4o",
        "gpt-4.1",
        "claude-opus-41",
        "gpt-5-mini",
        "gemini-2.5-pro",
        "claude-sonnet-4",
        "gpt-5",
        // "claude-opus-4.5",
        // "claude-sonnet-4.5"
      ]
    },
    "openrouter": {
      "models": {
        "deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (via Deepseek)",
          "options": {
            "provider": {
              "order": [
                "deepseek"
              ],
              "allow_fallbacks": false
            }
          }
        },
        "nex-agi/nex-n2-pro:free": {
          "name": "Nex N2 Pro (Free)"
        }
      }
    },
    // "openrouter": {
    //   "whitelist": [
    //     "anthropic/claude-opus-4.7",
    //     "google/gemini-3.1-pro-preview",
    //     "google/gemma-4-31b-it",
    //     "google/gemma-4-26b-a4b-it",
    //     "z-ai/glm-5.1",
    //     "z-ai/glm-4.7",
    //     "minimax/minimax-m2.5",
    //     "deepseek/deepseek-v3.2"
    //   ]
    // },
    "nvidia": {
      "whitelist": []
    },
    "google-vertex": {
      "whitelist": []
    },
    "vercel": {
      "whitelist": [
        "zai/glm-4.7",
        "minimax/minimax-m2.5"
      ]
    },
  }
}