{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-windsurf-codeium@beta"
  ],
  "small_model": "opencode/big-pickle",
  "agent": {
    "build": {
      "model": "github-copilot/claude-sonnet-4.6",
    },
    "cheap": {
      "mode": "primary",
      "model": "opencode/big-pickle",
      "prompt": "{file:./prompts/precise-prompt.md}"
    },
    "planner": {
      "mode": "primary",
      "model": "opencode/big-pickle",
      "prompt": "{file:./prompts/planner.md}",
      "description": "An agent that breaks down problems systematically and delegates to sub-agents"
    },
    "ultraplanner": {
      "mode": "primary",
      "model": "openrouter/anthropic/claude-opus-4.7",
      "prompt": "{file:./prompts/planner.md}",
      "description": "An agent that breaks down complex problems with deep reasoning and delegates to sub-agents",
      "permission": {
        "write": "deny",
        "question": "deny",
        "todowrite": "deny"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "github-copilot/claude-haiku-4.5"
    },
    "plan": {
      "disable": true
    },
  },
  "formatter": {
    "markdown": {
      "command": [
        "pnpx",
        "remark-cli@12.0.1",
        "$FILE",
        "--rc-path",
        "./remarkrc",
        "--output"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "provider": {
    "opencode": {
      "whitelist": [
        "big-pickle",
        "minimax-m2.5-free",
        "glm-5-free",
        "glm-5",
        "kimi-k2.5-free"
      ]
    },
    "github-copilot": {
      "models": {
        "gpt-5.3-codex": {}
      },
      "blacklist": [
        "grok-code-fast-1",
        "gpt-5.1-codex",
        // "claude-haiku-4.5",
        "gemini-3-pro-preview",
        "oswe-vscode-prime",
        "gpt-5.1-codex-mini",
        "gpt-5.1",
        "gpt-5-codex",
        "gpt-4o",
        "gpt-4.1",
        "claude-opus-41",
        "gpt-5-mini",
        "gemini-2.5-pro",
        "claude-sonnet-4",
        "gpt-5",
        // "claude-opus-4.5",
        // "claude-sonnet-4.5"
      ]
    },
    "openrouter": {
      "whitelist": [
        "anthropic/claude-opus-4.7",
        "google/gemma-4-31b-it",
        "google/gemma-4-26b-a4b-it",
        "z-ai/glm-4.7",
        "minimax/minimax-m2.5",
        "deepseek/deepseek-v3.2"
      ]
    },
    "nvidia": {
      "whitelist": []
    },
    "vertex": {
      "whitelist": []
    },
    "vercel": {
      "whitelist": [
        "zai/glm-4.7",
        "minimax/minimax-m2.5"
      ]
    },
    "windsurf": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:42100/v1"
      },
      "models": {
        "swe-1.5": {
          "name": "SWE 1.5 (Windsurf)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-4.5-sonnet": {
          "name": "Claude 4.5 Sonnet (Windsurf)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-4.5-opus": {
          "name": "Claude 4.5 Opus (Windsurf)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        }
      }
    }
  }
}