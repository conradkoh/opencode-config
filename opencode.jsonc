{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "small_model": "opencode/big-pickle",
  "agent": {
    "build": {
      "model": "opencode-go/deepseek-v4-pro",
      "permission": {
        "task": "deny"
      }
    },
    "cheap": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./prompts/precise-prompt.md}",
      "permission": {
        "task": "deny"
      }
    },
    "planner": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./prompts/planner.md}",
      "description": "An agent that breaks down problems systematically and delegates to sub-agents",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    },
    "ultraplanner": {
      "mode": "primary",
      "model": "openrouter/anthropic/claude-opus-4.7",
      "prompt": "{file:./prompts/planner.md}",
      "description": "An agent that breaks down complex problems with deep reasoning and delegates to sub-agents",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "plan": {
      "disable": true
    },
  },
  "formatter": {
    "markdown": {
      "command": [
        "pnpx",
        "remark-cli@12.0.1",
        "$FILE",
        "--rc-path",
        "./remarkrc",
        "--output"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3.6-27b": {
          "name": "Qwen 3.6-27B"
        },
        "google/gemma-4-e4b": {
          "name": "Gemma 4-E4B"
        }
      }
    },
    "opencode": {
      "whitelist": [
        "big-pickle",
        "minimax-m2.5-free",
        "glm-5-free",
        "glm-5",
        "kimi-k2.5-free"
      ]
    },
    "github-copilot": {
      "models": {
        "gpt-5.3-codex": {}
      },
      "blacklist": [
        "grok-code-fast-1",
        "gpt-5.1-codex",
        // "claude-haiku-4.5",
        "gemini-3-pro-preview",
        "oswe-vscode-prime",
        "gpt-5.1-codex-mini",
        "gpt-5.1",
        "gpt-5-codex",
        "gpt-4o",
        "gpt-4.1",
        "claude-opus-41",
        "gpt-5-mini",
        "gemini-2.5-pro",
        "claude-sonnet-4",
        "gpt-5",
        // "claude-opus-4.5",
        // "claude-sonnet-4.5"
      ]
    },
    "openrouter": {
      "whitelist": [
        "anthropic/claude-opus-4.7",
        "google/gemini-3.1-pro-preview",
        "google/gemma-4-31b-it",
        "google/gemma-4-26b-a4b-it",
        "z-ai/glm-5.1",
        "z-ai/glm-4.7",
        "minimax/minimax-m2.5",
        "deepseek/deepseek-v3.2"
      ]
    },
    "nvidia": {
      "whitelist": []
    },
    "google-vertex": {
      "whitelist": []
    },
    "vercel": {
      "whitelist": [
        "zai/glm-4.7",
        "minimax/minimax-m2.5"
      ]
    },
  }
}